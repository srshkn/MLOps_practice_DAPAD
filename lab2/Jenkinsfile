pipeline {
    agent any

    environment {
        WORKSPACE_DIR = "${WORKSPACE}"
        LAB2_DIR = "${WORKSPACE_DIR}/lab2"
        DATASET_DIR = "${LAB2_DIR}/dataset"
        PYTHON_ENV = "${WORKSPACE_DIR}/venv"
        // uv установит python в окружение, используем его
        PYTHON_BIN = "${PYTHON_ENV}/bin/python"
        DVC_REMOTE_NAME = 'storage'
        // Для Windows:
        // PYTHON_BIN = "${PYTHON_ENV}\\Scripts\\python"
    }

    stages {
        // На случай использования без CSM
        // stage('Checkout') {
        //     steps {
        //         git branch: 'lab2_test',
        //             url: 'https://github.com/srshkn/MLOps_practice_DAPAD.git',
        //             credentialsId: 'test_credentialsId'
        //     }
        // }

        stage('Setup Python Environment with uv') {
            steps {
                script {
                    sh '''
                        set -e

                        if ! command -v uv &> /dev/null; then
                            echo "uv не найден, устанавливаю..."
                            curl -LsSf https://astral.sh/uv/install.sh | sh
                        fi

                        # Добавляем типичный путь установки uv (на случай установки в ~/.local/bin)
                        export PATH="$HOME/.local/bin:$PATH"

                        # Убедимся, что uv доступен
                        uv --version

                        # Определяем, доступен ли CUDA-драйвер
                        UV_EXTRA="cpu"
                        if command -v nvidia-smi &> /dev/null && nvidia-smi > /dev/null 2>&1; then
                            UV_EXTRA="cu128"
                            echo "CUDA-драйвер найден, использую --extra ${UV_EXTRA}"
                        else
                            echo "CUDA недоступна или драйвер не установлен, использую --extra ${UV_EXTRA}"
                        fi

                        # Создаём виртуальное окружение
                        uv venv "${PYTHON_ENV}"

                        # Устанавливаем зависимости из pyproject.toml с нужным extra
                        uv sync --project "${WORKSPACE_DIR}" --python "${PYTHON_BIN}" --extra "${UV_EXTRA}"
                    '''
                }
            }
        }

        stage('Setup DVC') {
            steps {
                sh '''
                    set -e
                    export PATH="$HOME/.local/bin:$PATH"
                    cd "${WORKSPACE_DIR}"

                    if [ ! -d .dvc ]; then
                        dvc init --subdir
                    fi

                    if [ -n "${DVC_REMOTE_URL:-}" ]; then
                        dvc remote add -f -d "${DVC_REMOTE_NAME}" "${DVC_REMOTE_URL}"
                    fi

                    if [ -n "${DVC_S3_ENDPOINT_URL:-}" ]; then
                        dvc remote modify "${DVC_REMOTE_NAME}" endpointurl "${DVC_S3_ENDPOINT_URL}"
                    fi

                    if ! dvc remote list | grep -q "^${DVC_REMOTE_NAME}[[:space:]]"; then
                        echo "DVC remote '${DVC_REMOTE_NAME}' не настроен. Укажите DVC_REMOTE_URL в Jenkins environment."
                        exit 1
                    fi
                '''
            }
        }

        stage('Data Creation') {
            steps {
                sh "cd ${LAB2_DIR} && ${PYTHON_BIN} data_creation.py"
            }
        }

        stage('Data Preprocessing') {
            steps {
                sh "cd ${LAB2_DIR} && ${PYTHON_BIN} data_preprocessing.py"
            }
        }

        stage('Train Model') {
            steps {
                sh "cd ${LAB2_DIR} && ${PYTHON_BIN} fit.py > fit.log 2>&1"
            }
        }

        stage('Test Model') {
            steps {
                sh "cd ${LAB2_DIR} && ${PYTHON_BIN} model_testing.py > test.log 2>&1"
            }
        }

        stage('Validate Metrics') {
            steps {
                script {
                    def metrics = readJSON file: 'lab2/metrics.json'
                    env.METRICS_OK = metrics.accuracy >= 0.8 ? 'true' : 'false'

                    if (metrics.accuracy < 0.8) {
                        unstable("Accuracy слишком низкая: ${metrics.accuracy}")
                    }
                }
            }
        }

        stage('Publish Dataset To DVC') {
            when {
                expression { env.METRICS_OK == 'true' }
            }
            steps {
                sh '''
                    set -e
                    export PATH="$HOME/.local/bin:$PATH"
                    cd "${WORKSPACE_DIR}"

                    dvc add "${DATASET_DIR}"
                    dvc push
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'lab2/*.pkl, lab2/*.json, lab2/*.csv, lab2/*.log', fingerprint: true
            }
        }
        
    }

    post {
        success {
            script {
                // Пушим в main при успехе
                withCredentials([gitUsernamePassword(credentialsId: 'test_credentialsId')]) {
                    sh '''
                        set -e
                        git config user.email "jenkins@example.com"
                        git config user.name "Jenkins CI"
                        # Коммитим артефакты модели и DVC-метаданные датасета
                        git add .dvc .dvcignore lab2/*.pkl lab2/*.json lab2/*.csv lab2/*.log lab2/*.dvc
                        # Проверяем, есть ли изменения для коммита
                        if ! git diff --cached --quiet; then
                            git commit -m "Publish model and dataset metadata for build #${BUILD_NUMBER} [skip ci]"
                            git push origin HEAD:main
                        else
                            echo "Нет изменений для коммита"
                        fi
                    '''
                }
            }
            echo '✅ ML Pipeline completed successfully!'
        }

        unstable {
            script {
                // При плохих метриках сохраняем артефакты в отдельную debug-ветку
                withCredentials([gitUsernamePassword(credentialsId: 'test_credentialsId')]) {
                    sh '''
                        set -e
                        git config user.email "jenkins@example.com"
                        git config user.name "Jenkins CI"
                        git checkout -B debug-${BUILD_NUMBER}
                        git add lab2/*.pkl lab2/*.json lab2/*.csv lab2/*.txt lab2/*.log
                        if ! git diff --cached --quiet; then
                            git commit -m "Preserve low-metric build #${BUILD_NUMBER} [skip ci]"
                            git push origin debug-${BUILD_NUMBER}
                        else
                            echo "Нет изменений для коммита"
                        fi
                    '''
                }
            }
            echo '⚠️ Quality gate failed. Debug branch created.'
        }

        failure {
            echo '❌ ML Pipeline failed. Check logs for details.'
        }

        cleanup {
            cleanWs()
        }
    }
}